# ==============================================================================
# Threads Unfollower Tracker Configuration / Yapılandırma
# ==============================================================================
# EN: Extract these from Chrome DevTools (Network tab) when viewing threads.com
# TR: Bu değerleri threads.com adresini tarayıcınızda açıp Chrome Geliştirici
#     Araçları (Network / Ağ sekmesi) üzerinden alabilirsiniz.
# ==============================================================================

# 1. Cookie String / Çerez Değeri
# EN: The complete Cookie string (from the Request Headers of a request to threads.com)
# TR: threads.com'a giden herhangi bir isteğin Request Headers (İstek Başlıkları)
#     kısmındaki tüm "cookie" değerini buraya yapıştırın.
THREADS_COOKIE="ig_did=...; cb=...; csrftoken=...; ds_user_id=...; sessionid=..."

# 2. User-Agent / Tarayıcı Kimliği
# EN: The User-Agent string of your browser
# TR: Tarayıcınızın User-Agent (Kullanıcı Temsilcisi) değerini buraya girin.
THREADS_USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/149.0.0.0 Safari/537.36"

# 3. App ID / Uygulama Kimliği
# EN: The App ID (default is 238260118697367)
# TR: Threads Uygulama Kimliği (Varsayılan değer: 238260118697367)
THREADS_APP_ID="238260118697367"

# 4. LSD Token / LSD Simgesi
# EN: The LSD token (from the Form Data or headers, e.g. x-fb-lsd)
# TR: Form verilerinden veya başlıklarından alınan LSD belirteci (Örn: x-fb-lsd veya lsd)
THREADS_LSD="your_lsd_token_here"